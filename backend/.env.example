# SerpAPI key for Google Maps reviews (required in production)
SERPAPI_KEY=your_serpapi_key_here

# Comma-separated list of allowed frontend origins (required on Vercel)
# Example: https://your-site.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Local dev only (optional)
PORT=5000
